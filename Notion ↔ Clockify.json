    {
      "parameters": {
        "jsCode": "const notionTasks = $('Задачи из Notion').all();\nconst clockifyTasks = $('Все задачи Clockify').all();\n\nconst validClockifyTasks = clockifyTasks.filter(t => !t.json.error && t.json.id);\n\nconst clockifyMap = new Map();\nvalidClockifyTasks.forEach(t => {\n  clockifyMap.set(t.json.id, t.json);\n});\n\nconst toUpdate = [];\n\nnotionTasks.forEach(task => {\n  const notionName = task.json.property_name;\n  const clockifyId = task.json.property_clockify_task_id;\n  \n  if (!clockifyId) return;\n  \n  const clockifyTask = clockifyMap.get(clockifyId);\n  \n  if (!clockifyTask) return;\n  \n  if (clockifyTask.name !== notionName) {\n    toUpdate.push({\n      json: {\n        task_id: clockifyId,\n        workspace_id: '68e89f2b631c3b32396fc00c',\n        project_id: clockifyTask.projectId,\n        new_name: notionName,\n        old_name: clockifyTask.name\n      }\n    });\n  }\n});\n\nif (toUpdate.length === 0) {\n  return [{ json: { skip: true, message: 'No updates needed' } }];\n}\n\nreturn toUpdate;"
