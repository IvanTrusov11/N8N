      ],
      "id": "6f441953-6332-4897-a556-e4fb692fb55d",
      "name": "Сгруппировать время по задачам"
    },
    {
      "parameters": {
        "jsCode": "const notionTasks = $('Задачи из Notion').all();\nconst clockifyTime = $input.all();\n\nconst result = [];\n\nclockifyTime.forEach(timeEntry => {\n  const clockifyTaskId = timeEntry.json.clockify_task_id;\n  const totalMinutes = timeEntry.json.total_minutes;\n  \n  // Ищем соответствующую задачу в Notion\n  const notionTask = notionTasks.find(t => \n    t.json.property_clockify_task_id === clockifyTaskId\n  );\n  \n  if (notionTask) {\n    result.push({\n      json: {\n        notion_page_id: notionTask.json.id,\n        notion_task_name: notionTask.json.property_name,\n        clockify_task_id: clockifyTaskId,\n        total_minutes: totalMinutes\n      }\n    });\n  }\n});\n\nif (result.length === 0) {\n  return [{ json: { skip: true, message: 'No matching tasks' } }];\n}\n\nreturn result;"
      },
