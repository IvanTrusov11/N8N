    {
      "parameters": {
        "jsCode": "const createdTasks = $input.all();\nconst originalTasks = $('Анализ задач').all();\n\n// ОТЛАДКА\nconsole.log('Created tasks count:', createdTasks.length);\nconsole.log('First created task:', createdTasks[0]);\n\nconst result = [];\n\nfor (let i = 0; i < createdTasks.length; i++) {\n  const created = createdTasks[i].json;\n  \n  console.log(`Task ${i}:`, created);\n  \n  if (!created || !created.id) {\n    console.log(`Skipped task ${i} - no ID`);\n    continue;\n  }\n  \n  const original = originalTasks[i].json;\n  \n  result.push({\n    json: {\n      page_id: original.notion_id,\n      task_id: created.id\n    }\n  });\n}\n\nconsole.log('Result count:', result.length);\n\nif (result.length === 0) {\n  return [{json: {skip: true}}];\n}\n\nreturn result;"
