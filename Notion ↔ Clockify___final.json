    {
      "parameters": {
        "jsCode": "const notionTasks = $('Задачи из Notion').all();\nconst clockifyProjects = $('Проверка/Добавление проектов').all();\n\nconsole.log('=== NOTION TASKS ===', notionTasks.length);\nconsole.log('=== CLOCKIFY PROJECTS ===', clockifyProjects.length);\n\n// Архивные проекты - не создаём\nconst archived = ['Biznes-Hat', 'IvTru11', 'Oboltrade', 'Skyway'];\n\n// Уникальные проекты из Notion\nconst notionProjects = [...new Set(\n  notionTasks.map(t => t.json.property_prj).filter(p => p && !archived.includes(p))\n)];\n\nconsole.log('=== UNIQUE NOTION PROJECTS ===', notionProjects);\n\n// Фильтруем только активные проекты Clockify\nconst activeClockifyProjects = clockifyProjects.filter(p => \n  p.json && p.json.archived === false\n);\n\nconsole.log('=== ACTIVE CLOCKIFY ===', activeClockifyProjects.length);\n\n// Map проектов (название → ID)\nconst clockifyMap = new Map();\nactiveClockifyProjects.forEach(p => {\n  if (p.json && p.json.name && p.json.id) {\n    clockifyMap.set(p.json.name, p.json.id);\n  }\n});\n\nconsole.log('=== PROJECTS IN MAP ===', Array.from(clockifyMap.keys()));\n\n// Находим что создать\nconst toCreate = [];\nnotionProjects.forEach(name => {\n  if (!clockifyMap.has(name)) {\n    toCreate.push({json: {project_name: name}});\n    console.log('🆕 CREATE:', name);\n  } else {\n    console.log('✅ EXISTS:', name);\n  }\n});\n\nif (toCreate.length === 0) {\n  return [{json: {skip: true}}];\n}\n\nreturn toCreate;"
      },
