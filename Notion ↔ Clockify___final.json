    {
      "parameters": {
        "jsCode": "const notionTasks = $('Задачи из Notion').all();\nconst clockifyTasks = $('Все задачи Clockify').all();\n\nconst notionClockifyIds = new Set();\nnotionTasks.forEach(task => {\n  const clockifyId = task.json.property_clockify_task_id;\n  if (clockifyId) {\n    notionClockifyIds.add(clockifyId);\n  }\n});\n\nconst toDelete = [];\n\nclockifyTasks.forEach(item => {\n  const task = item.json;\n  \n  if (task.id && !notionClockifyIds.has(task.id)) {\n    toDelete.push({\n      json: {\n        task_id: task.id,\n        workspace_id: '68e89f2b631c3b32396fc00c',\n        project_id: task.projectId,\n        task_name: task.name\n      }\n    });\n  }\n});\n\nif (toDelete.length === 0) {\n  return [{ json: { skip: true, message: 'No tasks to delete' } }];\n}\n\nreturn toDelete;"
