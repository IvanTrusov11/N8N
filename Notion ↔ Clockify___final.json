    {
      "parameters": {
        "jsCode": "const notionTasks = $('Задачи из Notion').all();\nconst clockifyProjects = $('Все проекты').all();\n\n// Map проектов (название → ID)\nconst projectMap = new Map();\nclockifyProjects.forEach(p => {\n  if (p.json && p.json.name && p.json.id) {\n    projectMap.set(p.json.name, p.json.id);\n  }\n});\n\n// Готовим задачи БЕЗ Clockify_Task_ID для создания\nconst result = [];\n\nnotionTasks.forEach(task => {\n  const projectName = task.json.property_prj;\n  const taskName = task.json.property_name;\n  const notionId = task.json.id;\n  const clockifyTaskId = task.json.property_clockify_task_id;\n  \n  // Пропускаем задачи без проекта\n  if (!projectName) return;\n  \n  // Находим ID проекта\n  const projectId = projectMap.get(projectName);\n  \n  if (!projectId) return;\n  \n  // Создаем ТОЛЬКО задачи БЕЗ ID\n  if (!clockifyTaskId || clockifyTaskId === '') {\n    result.push({\n      json: {\n        notion_id: notionId,\n        task_name: taskName,\n        project_name: projectName,\n        project_id: projectId\n      }\n    });\n  }\n});\n\nreturn result.length > 0 ? result : [{json: {skip: true}}];"
      },
