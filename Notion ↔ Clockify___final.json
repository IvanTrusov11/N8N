    {
      "parameters": {
        "jsCode": "const timeEntries = $input.all();\n\n// Группируем по taskId и суммируем время\nconst taskTimeMap = new Map();\n\ntimeEntries.forEach(entry => {\n  const taskId = entry.json.taskId;\n  \n  // Пропускаем треки без задачи\n  if (!taskId) return;\n  \n  const duration = entry.json.timeInterval.duration;\n  \n  // Конвертируем PT формат в секунды\n  let seconds = 0;\n  const matches = duration.match(/PT(?:(\\d+)H)?(?:(\\d+)M)?(?:(\\d+)S)?/);\n  if (matches) {\n    const hours = parseInt(matches[1] || 0);\n    const minutes = parseInt(matches[2] || 0);\n    const secs = parseInt(matches[3] || 0);\n    seconds = hours * 3600 + minutes * 60 + secs;\n  }\n  \n  // Суммируем\n  if (taskTimeMap.has(taskId)) {\n    taskTimeMap.set(taskId, taskTimeMap.get(taskId) + seconds);\n  } else {\n    taskTimeMap.set(taskId, seconds);\n  }\n});\n\n// Конвертируем в массив и переводим в минуты\nconst result = [];\ntaskTimeMap.forEach((totalSeconds, taskId) => {\n  const minutes = Math.round(totalSeconds / 60); // округление до целых минут\n  result.push({\n    json: {\n      clockify_task_id: taskId,\n      total_minutes: minutes,\n      total_seconds: totalSeconds\n    }\n  });\n});\n\nif (result.length === 0) {\n  return [{ json: { skip: true, message: 'No time entries with tasks' } }];\n}\n\nreturn result;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        112,
