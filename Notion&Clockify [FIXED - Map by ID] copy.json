    {
      "parameters": {
        "jsCode": "// Получаем задачи из Clockify\nconst clockifyTasks = $input.all();\n\n// Получаем задачи из Notion\nconst notionTasks = $('Get Notion Tasks').all();\n\n// Получаем проекты из Clockify\nconst clockifyProjects = $('Get All Projects from Clockify').all();\n\n// Создаем маппинг: projectId -> projectName\nconst projectIdToName = {};\nclockifyProjects.forEach(project => {\n  projectIdToName[project.json.id] = project.json.name;\n});\n\n// Создаем маппинг: projectName + taskName -> clockify task\nconst clockifyTaskMap = {};\nclockifyTasks.forEach(task => {\n  const projectName = projectIdToName[task.json.projectId];\n  if (projectName && task.json.name) {\n    const key = `${projectName}|||${task.json.name}`;\n    clockifyTaskMap[key] = task.json.id;\n  }\n});\n\n// Сопоставляем с Notion\nconst result = [];\n\nnotionTasks.forEach(notionTask => {\n  const notionProjectName = notionTask.json.property_prj;\n  const notionTaskName = notionTask.json.property_name;\n  const existingClockifyId = notionTask.json.property_clockify_task_id;\n  \n  if (!notionProjectName || !notionTaskName) return;\n  \n  const key = `${notionProjectName}|||${notionTaskName}`;\n  const clockifyTaskId = clockifyTaskMap[key];\n  \n  if (clockifyTaskId && !existingClockifyId) {\n    // Нашли задачу в Clockify, но в Notion нет ID\n    result.push({\n      json: {\n        notion_id: notionTask.json.id,\n        clockify_task_id: clockifyTaskId,\n        task_name: notionTaskName,\n        project_name: notionProjectName,\n        action: 'update_id'\n      }\n    });\n  }\n});\n\nreturn result;"
      },
