        "jsonBody": "={\n  \"dateRangeStart\": \"2025-09-01T00:00:00.000Z\",\n  \"dateRangeEnd\": \"2025-10-15T23:59:59.999Z\",\n  \"detailedFilter\": {\n    \"page\": 1,\n    \"pageSize\": 1000\n  }\n}",
