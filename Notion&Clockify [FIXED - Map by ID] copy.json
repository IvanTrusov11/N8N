      "parameters": {
        "jsCode": "// Извлекаем уникальные проекты из Notion\nconst items = $input.all();\n\nconst archivedProjects = ['Biznes-Hat', 'IvTru11', 'Oboltrade'];\n\nconst uniqueProjects = [...new Set(items.map(item => item.json.property_prj))];\n\nconst activeProjects = uniqueProjects.filter(p => \n  p && p !== null && !archivedProjects.includes(p)\n);\n\nreturn activeProjects.map(project => ({\n  json: {\n    project_name: project\n  }\n}));"
      },
