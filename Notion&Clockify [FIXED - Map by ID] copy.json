        "jsCode": "// После создания задачи - сохраняем её ID\nconst items = $input.all();\n\nreturn items.map(item => {\n  const originalData = item.json;\n  \n  return {\n    json: {\n      notion_id: originalData.notion_id || item.json.notion_id,\n      clockify_task_id: item.json.id || item.json.clockify_task_id,\n      tracked_minutes: originalData.tracked_minutes || 0\n    }\n  };\n});"
