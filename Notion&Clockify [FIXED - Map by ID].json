    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\n// АРХИВНЫЕ ПРОЕКТЫ\nconst archivedProjects = ['Biznes-Hat', 'IvTru11', 'Oboltrade'];\n\n// Извлекаем уникальные проекты\nconst uniqueProjects = [...new Set(items.map(item => item.json.property_prj))];\n\n// Исключаем архивные и null\nconst activeProjects = uniqueProjects.filter(p => \n  p && p !== null && !archivedProjects.includes(p)\n);\n\nreturn activeProjects.map(project => ({\n  json: {\n    project_name: project\n  }\n}));"
      },
