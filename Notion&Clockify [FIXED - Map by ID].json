    {
      "parameters": {
        "jsCode": "// DEBUG: Получаем данные из предыдущих узлов\nconst timeEntries = $input.all(); // Time entries из HTTP Request2\nconst notionTasks = $('Get many database pages').all(); // Задачи из Notion\n\n// Выводим для отладки\nconsole.log('=== TIME ENTRIES COUNT:', timeEntries.length);\nconsole.log('=== NOTION TASKS COUNT:', notionTasks.length);\n\n// Смотрим структуру первого time entry\nif (timeEntries.length > 0) {\n  console.log('=== SAMPLE TIME ENTRY:', JSON.stringify(timeEntries[0].json, null, 2));\n}\n\n// Смотрим структуру первой Notion задачи\nif (notionTasks.length > 0) {\n  console.log('=== SAMPLE NOTION TASK:', JSON.stringify(notionTasks[0].json, null, 2));\n}\n\n// Собираем все projectId и taskId из time entries\nconst timeEntryKeys = timeEntries.map(entry => ({\n  projectId: entry.json.projectId || entry.json.project?.id,\n  taskId: entry.json.taskId || entry.json.task?.id,\n  description: entry.json.description,\n  workspaceId: entry.json.workspaceId\n}));\n\nconsole.log('=== TIME ENTRY KEYS:', JSON.stringify(timeEntryKeys.slice(0, 5), null, 2));\n\n// Собираем все данные из Notion задач\nconst notionKeys = notionTasks.map(task => ({\n  notionId: task.json.id,\n  name: task.json.property_name || task.json.name?.title?.[0]?.text?.content,\n  projectId: task.json.property_project?.[0]?.id,\n  workspaceId: task.json.workspaceId,\n  allProperties: Object.keys(task.json)\n}));\n\nconsole.log('=== NOTION KEYS:', JSON.stringify(notionKeys.slice(0, 5), null, 2));\n\n// Возвращаем тестовый результат\nreturn [{\n  json: {\n    debug: true,\n    timeEntriesCount: timeEntries.length,\n    notionTasksCount: notionTasks.length,\n    message: \"Проверьте консоль браузера для деталей\"\n  }\n}];"
      },
