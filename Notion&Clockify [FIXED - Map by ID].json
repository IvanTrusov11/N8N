        "jsCode": "// Получаем созданные tasks из Clockify (узел 8)\nconst clockifyTasks = $input.all();\n\n// Получаем исходные данные из Code1 (узел 7)\nconst originalTasks = $('Code in JavaScript1').all();\n\n// Создаем мапу notion_id -> Clockify task data\nconst result = [];\n\nclockifyTasks.forEach((clockifyTask, index) => {\n  const originalTask = originalTasks[index];\n  \n  if (originalTask && !clockifyTask.json.error) {\n    result.push({\n      json: {\n        notion_id: originalTask.json.notion_id,\n        clockify_task_id: clockifyTask.json.id\n      }\n    });\n  }\n});\n\nreturn result;"
