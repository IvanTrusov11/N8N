          "name": "Header Auth account Clockify&Notion"
        }
      },
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "// Получаем отчет из Clockify\nconst response = $input.first().json;\nconst timeEntries = response.timeentries || [];\n\n// Получаем задачи из Notion\nconst notionTasks = $('Get many database pages').all();\n\n// Шаг 1: Собираем уникальные задачи из Clockify (из time entries)\nconst clockifyTasks = {};\n\ntimeEntries.forEach(entry => {\n  const taskId = entry.taskId;\n  const taskName = entry.taskName;\n  const projectName = entry.projectName;\n  const projectId = entry.projectId;\n  \n  if (taskId && taskName && projectName && projectId) {\n    clockifyTasks[taskId] = {\n      taskId: taskId,\n      taskName: taskName,\n      projectName: projectName,\n      projectId: projectId\n    };\n  }\n});\n\n// DEBUG: Clockify задачи\nconst debugClockifyTasks = Object.values(clockifyTasks).slice(0, 5);\n\n// Шаг 2: Сопоставляем с Notion и записываем ID (если нет)\nconst tasksToUpdate = [];\n\nnotionTasks.forEach(notionTask => {\n  const notionProject = notionTask.json.property_prj;\n  const notionTaskName = notionTask.json.property_name;\n  const existingClockifyId = notionTask.json.property_clockify_task_id;\n  \n  // Если ID уже есть - пропускаем\n  if (existingClockifyId) return;\n  \n  // Ищем совпадение по названиям\n  for (const clockifyTask of Object.values(clockifyTasks)) {\n    if (clockifyTask.projectName === notionProject && \n        clockifyTask.taskName === notionTaskName) {\n      \n      tasksToUpdate.push({\n        json: {\n          notion_id: notionTask.json.id,\n          clockify_task_id: clockifyTask.taskId,\n          task_name: notionTaskName,\n          project_name: notionProject,\n          project_id: clockifyTask.projectId\n        }\n      });\n      \n      break;\n    }\n  }\n});\n\n// Если нашли задачи без ID - возвращаем их для записи ID\nif (tasksToUpdate.length > 0) {\n  return tasksToUpdate;\n}\n\n// Шаг 3: Если все задачи уже имеют ID - мапим время\nconst timeByTaskId = {};\n\ntimeEntries.forEach(entry => {\n  const taskId = entry.taskId;\n  if (!taskId) return;\n  \n  const duration = entry.timeInterval?.duration || 0;\n  const minutes = Math.round(duration / 60);\n  \n  if (!timeByTaskId[taskId]) {\n    timeByTaskId[taskId] = 0;\n  }\n  \n  timeByTaskId[taskId] += minutes;\n});\n\n// DEBUG: Собираем info о Notion задачах с Clockify ID\nconst notionTasksWithId = [];\nnotionTasks.forEach(task => {\n  const clockifyTaskId = task.json.property_clockify_task_id;\n  if (clockifyTaskId) {\n    notionTasksWithId.push({\n      notion_id: task.json.id,\n      task_name: task.json.property_name,\n      clockify_task_id: clockifyTaskId,\n      has_time: !!timeByTaskId[clockifyTaskId],\n      time_minutes: timeByTaskId[clockifyTaskId] || 0\n    });\n  }\n});\n\n// Мапим с Notion по ID\nconst updates = [];\n\nnotionTasks.forEach(task => {\n  const clockifyTaskId = task.json.property_clockify_task_id;\n  \n  if (clockifyTaskId && timeByTaskId[clockifyTaskId]) {\n    updates.push({\n      json: {\n        notion_id: task.json.id,\n        tracked_minutes: timeByTaskId[clockifyTaskId]\n      }\n    });\n  }\n});\n\n// ВОЗВРАЩАЕМ DEBUG INFO\nreturn [{\n  json: {\n    debug: true,\n    total_clockify_tasks: Object.keys(clockifyTasks).length,\n    total_notion_tasks: notionTasks.length,\n    notion_tasks_with_clockify_id: notionTasksWithId.length,\n    total_updates: updates.length,\n    clockify_tasks_sample: debugClockifyTasks,\n    notion_tasks_with_id: notionTasksWithId.slice(0, 20),\n    time_by_task_id: timeByTaskId,\n    updates: updates\n  }\n}];"
      },
