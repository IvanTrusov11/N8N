        "jsCode": "// ИСПРАВЛЕННЫЙ КОД - МАПИТ ПО CLOCKIFY TASK ID!\n\nconst timeReport = $input.first().json;\nconst timeEntries = timeReport.timeentries || [];\n\n// Получаем задачи из Notion\nconst notionTasks = $('Get Notion Tasks').all();\n\n// Получаем проекты из Clockify\nconst clockifyProjects = $('Get All Projects from Clockify').all().map(item => item.json).flat();\n\n// Создаем маппинг времени по Task ID\nconst timeByTaskId = {};\n\ntimeEntries.forEach(entry => {\n  const taskId = entry.taskId;\n  if (!taskId) return;\n  \n  const duration = entry.timeInterval?.duration || 0;\n  const minutes = Math.round(duration / 60);\n  \n  if (!timeByTaskId[taskId]) {\n    timeByTaskId[taskId] = 0;\n  }\n  \n  timeByTaskId[taskId] += minutes;\n});\n\n// Создаем маппинг проектов: название -> ID\nconst projectNameToId = {};\nclockifyProjects.forEach(project => {\n  projectNameToId[project.name] = project.id;\n});\n\n// Разделяем задачи на 2 типа:\n// 1. Задачи С Clockify_Task_ID - обновляем TRACK\n// 2. Задачи БЕЗ Clockify_Task_ID - создаем в Clockify\n\nconst tasksToUpdate = [];\nconst tasksToCreate = [];\n\nnotionTasks.forEach(task => {\n  const clockifyTaskId = task.json.property_clockify_task_id;\n  const taskName = task.json.property_name;\n  const projectName = task.json.property_prj;\n  const notionId = task.json.id;\n  \n  if (clockifyTaskId) {\n    // Задача уже имеет ID - обновляем время если есть\n    const trackedMinutes = timeByTaskId[clockifyTaskId] || 0;\n    \n    tasksToUpdate.push({\n      json: {\n        notion_id: notionId,\n        clockify_task_id: clockifyTaskId,\n        tracked_minutes: trackedMinutes,\n        task_name: taskName\n      }\n    });\n  } else {\n    // Задача НЕ имеет ID - нужно создать в Clockify\n    const projectId = projectNameToId[projectName];\n    \n    if (projectId && taskName) {\n      tasksToCreate.push({\n        json: {\n          notion_id: notionId,\n          task_name: taskName,\n          project_name: projectName,\n          project_id: projectId,\n          tracked_minutes: 0\n        }\n      });\n    }\n  }\n});\n\n// Возвращаем оба типа задач\nreturn [\n  ...tasksToUpdate,\n  ...tasksToCreate\n];"
      },
