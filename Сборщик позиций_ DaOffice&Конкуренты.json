    {
      "parameters": {
        "jsCode": "const cfg     = $('Config').first().json;\nconst results = $('Prepare Keywords').all().map(i => i.json);\nif (!results.length) return $input.all();\n\nconst r    = results[0];\nconst date = r.dateStr;\nconst data = [];\n\ndata.push({ range: `${cfg.MAIN_SHEET}!${r.mainYaCol}1`, values: [[`Я ${date}`]] });\ndata.push({ range: `${cfg.MAIN_SHEET}!${r.mainGCol}1`,  values: [[`G ${date}`]] });\ndata.push({ range: `${cfg.YA_SHEET}!${r.yaNextCol}1`,   values: [[date]] });\ndata.push({ range: `${cfg.G_SHEET}!${r.gNextCol}1`,     values: [[date]] });\n\nfor (const comp of (r.competitors || [])) {\n  const cols = r.competitorCols[comp];\n  if (!cols) continue;\n  data.push({ range: `'${comp}'!${cols.yaCol}1`, values: [[`Я ${date}`]] });\n  data.push({ range: `'${comp}'!${cols.gCol}1`,  values: [[`G ${date}`]] });\n}\n\nreturn [{ json: { body: { valueInputOption: 'USER_ENTERED', data } } }];"
      },
