    {
      "parameters": {
        "jsCode": "const cfg = $('Config').first().json;\nconst DOMAIN = 'daoffice.ru';\n\nconst now = new Date();\nconst dd  = String(now.getDate()).padStart(2, '0');\nconst mm  = String(now.getMonth() + 1).padStart(2, '0');\nconst dateStr = `${dd}.${mm}`;\n\nfunction colLetter(n) {\n  let r = '';\n  while (n > 0) {\n    n--;\n    r = String.fromCharCode(65 + (n % 26)) + r;\n    n = Math.floor(n / 26);\n  }\n  return r;\n}\n\nconst allRows = $('Читаем ALL').all();\nconst allKeys = allRows.length > 0\n  ? Object.keys(allRows[0].json).filter(k => !k.startsWith('__') && k !== 'row_number')\n  : [];\nlet allColCount = Math.max(allKeys.length, 2);\n\nconst todayYaHeader = `Я ${dateStr}`;\nlet mainYaCol, mainGCol;\nlet isResume = false;\n\nif (allKeys.includes(todayYaHeader)) {\n  const colIndex = allKeys.indexOf(todayYaHeader);\n  mainYaCol = colLetter(colIndex + 1);\n  mainGCol  = colLetter(colIndex + 2);\n  isResume = true;\n} else {\n  mainYaCol = colLetter(allColCount + 1);\n  mainGCol  = colLetter(allColCount + 2);\n}\n\nconst filledRows = new Set();\nif (isResume) {\n  for (const row of allRows) {\n    const val = row.json[todayYaHeader];\n    if (val !== undefined && val !== null && val !== '') {\n      filledRows.add(String(row.json['row_number']));\n    }\n  }\n}\n\nconst yaRows = $('Читаем Яндекс').all();\nlet yaColCount = 2;\nif (yaRows.length > 0) {\n  const keys = Object.keys(yaRows[0].json).filter(k => !k.startsWith('__') && k !== 'row_number');\n  yaColCount = Math.max(keys.length, 2);\n}\nconst yaNextCol = isResume ? mainYaCol : colLetter(yaColCount + 1);\n\nconst gRows = $('Читаем Google').all();\nlet gColCount = 2;\nif (gRows.length > 0) {\n  const keys = Object.keys(gRows[0].json).filter(k => !k.startsWith('__') && k !== 'row_number');\n  gColCount = Math.max(keys.length, 2);\n}\nconst gNextCol = isResume ? mainGCol : colLetter(gColCount + 1);\n\n// Конкуренты\nconst competitorDomains = $('Читаем конкуренты').all()\n  .map(i => (i.json['домен'] || '').trim())\n  .filter(Boolean);\n\nconst batchResp = $('HTTP Request').first().json;\nconst valueRanges = batchResp.valueRanges || [];\n\nconst competitorCols = {};\nfor (let i = 0; i < competitorDomains.length; i++) {\n  const domain = competitorDomains[i];\n  const range = valueRanges[i];\n  const headers = (range && range.values && range.values[0]) ? range.values[0] : [];\n  const colCount = Math.max(headers.length, 2);\n  const todayCompHeader = `Я ${dateStr}`;\n  if (headers.includes(todayCompHeader)) {\n    const colIndex = headers.indexOf(todayCompHeader);\n    competitorCols[domain] = {\n      yaCol: colLetter(colIndex + 1),\n      gCol:  colLetter(colIndex + 2),\n    };\n  } else {\n    competitorCols[domain] = {\n      yaCol: colLetter(colCount + 1),\n      gCol:  colLetter(colCount + 2),\n    };\n  }\n}\n\nconst isFirstRun = allRows.length === 0;\nconst inputRows = $('Читаем ключи').all();\nconst results = [];\n\nfor (const item of inputRows) {\n  const kw = (item.json['Ключевой запрос'] || '').trim();\n  if (!kw) continue;\n  if (kw === 'Ключевой запрос') continue;\n\n  const demandVal = item.json['Спрос'];\n  const looksLikeDomain = kw.includes('.') && (kw.includes('.ru') || kw.includes('.рф') || kw.includes('.com'));\n  if (looksLikeDomain && (!demandVal || demandVal === '')) continue;\n\n  if (isResume && filledRows.has(String(item.json['row_number']))) continue;\n\n  results.push({\n    keyword:        kw,\n    demand:         demandVal || '',\n    rowNum:         item.json['row_number'],\n    domain:         DOMAIN,\n    dateStr,\n    mainYaCol,      mainGCol,\n    yaNextCol,      gNextCol,\n    competitors:    competitorDomains,\n    competitorCols,\n    isFirstRun,\n    yaUrl: `https://xmlstock.com/yandex/xml/?user=${cfg.XMLSTOCK_USER}&key=${cfg.XMLSTOCK_KEY}&query=${encodeURIComponent(kw)}&lr=${cfg.YANDEX_REGION}&groupby=100`,\n    gUrl:  `https://xmlstock.com/google/xml/?user=${cfg.XMLSTOCK_USER}&key=${cfg.XMLSTOCK_KEY}&query=${encodeURIComponent(kw)}&lr=ru&num=100&hl=ru`\n  });\n}\n\nreturn results.map(r => ({ json: r }));"
      },
