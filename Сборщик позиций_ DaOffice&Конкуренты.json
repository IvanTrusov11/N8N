    {
      "parameters": {
        "jsCode": "const r   = $('Parse Results').first().json;\nconst cfg = $('Config').first().json;\nconst data = [];\n\nconst yVal = r.yPos ? `=HYPERLINK(\"${r.yUrl}\";\"${r.yPos}\")` : (r.ya210 ? '210' : '—');\nconst gVal = r.gPos ? `=HYPERLINK(\"${r.gUrl}\";\"${r.gPos}\")` : (r.g210  ? '210' : '—');\n\ndata.push({ range: `${cfg.MAIN_SHEET}!${r.mainYaCol}${r.rowNum}`, values: [[yVal]] });\ndata.push({ range: `${cfg.MAIN_SHEET}!${r.mainGCol}${r.rowNum}`,  values: [[gVal]] });\n\nreturn [{ json: { body: { valueInputOption: 'USER_ENTERED', data } } }];"
