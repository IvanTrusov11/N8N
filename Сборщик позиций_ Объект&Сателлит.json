    {
      "parameters": {
        "jsCode": "const cfg = $('Config').first().json;\nconst DOMAIN = 'kurort-expert.ru';\n\nconst now = new Date();\nconst dd  = String(now.getDate()).padStart(2, '0');\nconst mm  = String(now.getMonth() + 1).padStart(2, '0');\nconst dateStr = `${dd}.${mm}`;\n\nfunction colLetter(n) {\n  let r = '';\n  while (n > 0) {\n    n--;\n    r = String.fromCharCode(65 + (n % 26)) + r;\n    n = Math.floor(n / 26);\n  }\n  return r;\n}\n\nconst allRows = $('Читаем ALL').all();\nconst allKeys = allRows.length > 0\n  ? Object.keys(allRows[0].json).filter(k => !k.startsWith('__') && k !== 'row_number')\n  : [];\nlet allColCount = Math.max(allKeys.length, 2);\n\n// Проверяем — есть ли уже столбец с сегодняшней датой\nconst todayYaHeader = `Я ${dateStr}`;\nlet mainYaCol, mainGCol, mainSatYaCol, mainSatGCol;\nlet isResume = false;\n\nif (allKeys.includes(todayYaHeader)) {\n  const colIndex = allKeys.indexOf(todayYaHeader);\n  mainYaCol    = colLetter(colIndex + 1);\n  mainGCol     = colLetter(colIndex + 2);\n  mainSatYaCol = colLetter(colIndex + 3);\n  mainSatGCol  = colLetter(colIndex + 4);\n  isResume = true;\n} else {\n  mainYaCol    = colLetter(allColCount + 1);\n  mainGCol     = colLetter(allColCount + 2);\n  mainSatYaCol = colLetter(allColCount + 3);\n  mainSatGCol  = colLetter(allColCount + 4);\n}\n\n// Строим множество уже заполненных строк\nconst filledRows = new Set();\nif (isResume) {\n  for (const row of allRows) {\n    const val = row.json[todayYaHeader];\n    if (val !== undefined && val !== null && val !== '') {\n      filledRows.add(String(row.json['row_number']));\n    }\n  }\n}\n\nconst yaRows = $('Читаем Яндекс').all();\nlet yaColCount = 2;\nif (yaRows.length > 0) {\n  const keys = Object.keys(yaRows[0].json).filter(k => !k.startsWith('__') && k !== 'row_number');\n  yaColCount = Math.max(keys.length, 2);\n}\nconst yaNextCol = isResume ? mainYaCol : colLetter(yaColCount + 1);\n\nconst gRows = $('Читаем Google').all();\nlet gColCount = 2;\nif (gRows.length > 0) {\n  const keys = Object.keys(gRows[0].json).filter(k => !k.startsWith('__') && k !== 'row_number');\n  gColCount = Math.max(keys.length, 2);\n}\nconst gNextCol = isResume ? mainGCol : colLetter(gColCount + 1);\n\nconst yaSRows = $('Читаем Яндекс-S').all();\nlet yaSColCount = 2;\nif (yaSRows.length > 0) {\n  const keys = Object.keys(yaSRows[0].json).filter(k => !k.startsWith('__') && k !== 'row_number');\n  yaSColCount = Math.max(keys.length, 2);\n}\nconst yaNextColS = isResume ? mainSatYaCol : colLetter(yaSColCount + 1);\n\nconst gSRows = $('Читаем Google-S').all();\nlet gSColCount = 2;\nif (gSRows.length > 0) {\n  const keys = Object.keys(gSRows[0].json).filter(k => !k.startsWith('__') && k !== 'row_number');\n  gSColCount = Math.max(keys.length, 2);\n}\nconst gNextColS = isResume ? mainSatGCol : colLetter(gSColCount + 1);\n\nconst isFirstRun = allRows.length === 0;\nconst inputRows = $('Читаем ключи').all();\nconst results = [];\nlet currentSatellite = '';\n\nfor (const item of inputRows) {\n  const kw = (item.json['Ключевой запрос'] || '').trim();\n  if (!kw) continue;\n  if (kw === 'Ключевой запрос') continue;\n\n  if (kw.includes('.рф')) {\n    const m = kw.match(/\\(([^)]+\\.рф)\\)/);\n    if (m) currentSatellite = m[1];\n    continue;\n  }\n\n  // Пропускаем уже заполненные строки\n  if (isResume && filledRows.has(String(item.json['row_number']))) continue;\n\n  results.push({\n    keyword:   kw,\n    demand:    item.json['Спрос'] || '',\n    rowNum:    item.json['row_number'],\n    domain:    DOMAIN,\n    satellite: currentSatellite,\n    dateStr,\n    mainYaCol, mainGCol, mainSatYaCol, mainSatGCol,\n    yaNextCol, gNextCol, yaNextColS, gNextColS,\n    isFirstRun,\n    yaUrl: `https://xmlstock.com/yandex/xml/?user=${cfg.XMLSTOCK_USER}&key=${cfg.XMLSTOCK_KEY}&query=${encodeURIComponent(kw)}&lr=${cfg.YANDEX_REGION}&groupby=100`,\n    gUrl:  `https://xmlstock.com/google/xml/?user=${cfg.XMLSTOCK_USER}&key=${cfg.XMLSTOCK_KEY}&query=${encodeURIComponent(kw)}&lr=ru&num=100&hl=ru`\n  });\n}\n\nreturn results.map(r => ({ json: r }));"
      },
