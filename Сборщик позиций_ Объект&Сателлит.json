    {
      "parameters": {
        "jsCode": "const cfg     = $('Config').first().json;\nconst results = $('Prepare Keywords').all().map(i => i.json);\nif (!results.length) return $input.all();\n\nconst r    = results[0];\nconst date = r.dateStr;\nconst data = [];\n\nconst sheets = [\n  { sheet: cfg.MAIN_SHEET,  cols: [r.mainYaCol, r.mainGCol, r.mainSatYaCol, r.mainSatGCol], labels: [`Я ${date}`, `G ${date}`, `Сат Я ${date}`, `Сат G ${date}`] },\n  { sheet: cfg.YA_SHEET,    cols: [r.yaNextCol],  labels: [date] },\n  { sheet: cfg.G_SHEET,     cols: [r.gNextCol],   labels: [date] },\n  { sheet: cfg.YA_S_SHEET,  cols: [r.yaNextColS], labels: [date] },\n  { sheet: cfg.G_S_SHEET,   cols: [r.gNextColS],  labels: [date] },\n];\n\nfor (const s of sheets) {\n  for (let i = 0; i < s.cols.length; i++) {\n    data.push({ range: `${s.sheet}!${s.cols[i]}1`, values: [[s.labels[i]]] });\n  }\n}\n\nreturn [{ json: { body: { valueInputOption: 'USER_ENTERED', data } } }];"
      },
