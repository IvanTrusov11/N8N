    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "function punycodeEncode(str) {\n  const base=36,tmin=1,tmax=26,skew=38,damp=700,initialBias=72,initialN=128;\n  const codePoints=Array.from(str).map(c=>c.codePointAt(0));\n  const basic=codePoints.filter(cp=>cp<128);\n  let handled=basic.length;\n  const output=basic.map(cp=>String.fromCodePoint(cp));\n  if(handled>0)output.push('-');\n  function adapt(delta,numPoints,first){delta=first?Math.floor(delta/damp):delta>>1;delta+=Math.floor(delta/numPoints);let k=0;while(delta>Math.floor(((base-tmin)*tmax)/2)){delta=Math.floor(delta/(base-tmin));k+=base;}return k+Math.floor(((base-tmin+1)*delta)/(delta+skew));}\n  function dig(d){return d+22+75*(d<26?1:0);}\n  let n=initialN,delta=0,bias=initialBias;\n  while(handled<codePoints.length){\n    const m=Math.min(...codePoints.filter(cp=>cp>=n));\n    delta+=(m-n)*(handled+1);n=m;\n    for(const cp of codePoints){\n      if(cp<n)delta++;\n      if(cp===n){let q=delta;for(let k=base;;k+=base){const t=k<=bias?tmin:k>=bias+tmax?tmax:k-bias;if(q<t)break;output.push(String.fromCodePoint(dig(t+(q-t)%(base-t))));q=Math.floor((q-t)/(base-t));}output.push(String.fromCodePoint(dig(q)));bias=adapt(delta,handled+1,handled===basic.length);delta=0;handled++;}\n    }\n    delta++;n++;\n  }\n  return output.join('');\n}\n\nfunction domainToASCII(domain) {\n  return domain.split('.').map(label=>\n    /[^\\x00-\\x7F]/.test(label)?'xn--'+punycodeEncode(label):label\n  ).join('.');\n}\n\nfunction parseXml(xmlStr, domain) {\n  if (!xmlStr || typeof xmlStr !== 'string') return { pos: null, url: null };\n  const docs = xmlStr.match(/<doc[\\s\\S]*?<\\/doc>/g) || [];\n  const domainLow  = domain.toLowerCase();\n  const domainPuny = domainToASCII(domain).toLowerCase();\n  for (let j = 0; j < docs.length; j++) {\n    const um = docs[j].match(/<url[^>]*>([^<]+)<\\/url>/);\n    if (!um) continue;\n    const urlLow = um[1].toLowerCase();\n    if (urlLow.includes(domainLow) || urlLow.includes(domainPuny)) {\n      return { pos: j + 1, url: um[1].trim() };\n    }\n  }\n  return { pos: null, url: null };\n}\n\nconst meta  = $('Split').item.json;\nconst yaXml = $('HTTP Яндекс').first().json.data || '';\nconst gXml  = $('HTTP Google').first().json.data || '';\n\nconst ya210 = yaXml.includes('code=\"210\"') || yaXml.includes('code=\"202\"');\nconst g210  = gXml.includes('code=\"210\"')  || gXml.includes('code=\"202\"');\n\n// DEBUG — собираем все коды ошибок\nconst yaErrors = (yaXml.match(/code=\"(\\d+)\"/g) || []);\nconst gErrors  = (gXml.match(/code=\"(\\d+)\"/g) || []);\n\nconst parsedY  = parseXml(yaXml, meta.domain);\nconst parsedG  = parseXml(gXml,  meta.domain);\nconst parsedSY = meta.satellite ? parseXml(yaXml, meta.satellite) : { pos: null, url: null };\nconst parsedSG = meta.satellite ? parseXml(gXml,  meta.satellite) : { pos: null, url: null };\n\nreturn {\n  keyword: meta.keyword, demand: meta.demand, rowNum: meta.rowNum,\n  domain: meta.domain, satellite: meta.satellite, dateStr: meta.dateStr,\n  mainYaCol: meta.mainYaCol, mainGCol: meta.mainGCol,\n  mainSatYaCol: meta.mainSatYaCol, mainSatGCol: meta.mainSatGCol,\n  yaNextCol: meta.yaNextCol, gNextCol: meta.gNextCol,\n  yaNextColS: meta.yaNextColS, gNextColS: meta.gNextColS,\n  isFirstRun: meta.isFirstRun,\n  ya210, g210,\n  yPos: parsedY.pos, yUrl: parsedY.url,\n  gPos: parsedG.pos, gUrl: parsedG.url,\n  syPos: parsedSY.pos, syUrl: parsedSY.url,\n  sgPos: parsedSG.pos, sgUrl: parsedSG.url,\n  _yaErrors: yaErrors,\n  _gErrors:  gErrors,\n};"
      },
