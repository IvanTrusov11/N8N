    {
      "parameters": {
        "jsCode": "const r = $('Parse Results').first().json;\nconst cfg = $('Config').first().json;\nconst data = [];\nconst yVal  = r.yPos  ? `=HYPERLINK(\"${r.yUrl}\";\"${r.yPos}\")`   : (r.ya210 ? '210' : '—');\nconst gVal  = r.gPos  ? `=HYPERLINK(\"${r.gUrl}\";\"${r.gPos}\")`   : (r.g210  ? '210' : '—');\nconst syVal = r.syPos ? `=HYPERLINK(\"${r.syUrl}\";\"${r.syPos}\")` : (r.ya210 ? '210' : '—');\nconst sgVal = r.sgPos ? `=HYPERLINK(\"${r.sgUrl}\";\"${r.sgPos}\")` : (r.g210  ? '210' : '—');\ndata.push({ range: `${cfg.MAIN_SHEET}!${r.mainYaCol}${r.rowNum}`,    values: [[yVal]] });\ndata.push({ range: `${cfg.MAIN_SHEET}!${r.mainGCol}${r.rowNum}`,     values: [[gVal]] });\ndata.push({ range: `${cfg.MAIN_SHEET}!${r.mainSatYaCol}${r.rowNum}`, values: [[syVal]] });\ndata.push({ range: `${cfg.MAIN_SHEET}!${r.mainSatGCol}${r.rowNum}`,  values: [[sgVal]] });\nreturn [{ json: { body: { valueInputOption: 'USER_ENTERED', data } } }];"
      },
