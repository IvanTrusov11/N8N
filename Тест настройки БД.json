    {
      "parameters": {
        "content": "## Область для загрузи PDF и прочих документов\n\nЧто нужно сделать по шагам:\n1. Вам нужны прямые API OpenAI\n2. Superbase аккаунт\n2.1. Создать векторную БД\n2.2. Вы можете создать 2 БД\n3. Запишите в БД данные",
        "height": 820,
        "width": 1440
      },
      "type": "n8n-nodes-base.stickyNote",
      "position": [
        -1184,
        80
      ],
      "typeVersion": 1,
      "id": "8e67d04f-e81d-4e78-a935-946500039ce7",
      "name": "Sticky Note1"
    },
    {
      "parameters": {
        "content": "## Код для создания векторной БД\n\n\n-- 1) Включить расширение pgvector (в Supabase обычно доступно как \"vector\")\nCREATE EXTENSION IF NOT EXISTS vector;\n\n-- 2) Создать таблицу documents\nCREATE TABLE IF NOT EXISTS documents (\n  id BIGSERIAL PRIMARY KEY,\n  content TEXT,\n  metadata JSONB,\n  embedding VECTOR(1536) -- замените 1536 на нужный вам размер векторов\n);\n\n-- 3) Опционально: создать индекс для ускорения поиска (IVFFlat). \n--    Подойдёт для больших наборов данных. Параметр 'lists' подберите эмпирически (e.g., 100, 1024).\n--    Для hnsw используйте: USING ivfflat(embedding) или USING hnsw (если сборка позволяет).\n--    Пример для ivfflat:\nCREATE INDEX IF NOT EXISTS idx_documents_embedding_ivfflat ON documents USING ivfflat (embedding vector_l2_ops) WITH (lists = 100);\n\n-- Если ваша версия pgvector поддерживает hnsw (search_method = 'hnsw'), можно создать:\n-- CREATE INDEX IF NOT EXISTS idx_documents_embedding_hnsw ON documents USING hnsw (embedding);\n\n-- 4) Функция поиска — SQL-версия с учётом фильтра и match_count\nCREATE OR REPLACE FUNCTION match_documents(\n  query_embedding VECTOR,\n  match_count INT DEFAULT NULL,\n  filter JSONB DEFAULT '{}'::JSONB\n)\nRETURNS TABLE (\n  id BIGINT,\n  content TEXT,\n  metadata JSONB,\n  similarity DOUBLE PRECISION\n)\nLANGUAGE sql\nAS $$\n  SELECT\n    d.id,\n    d.content,\n    d.metadata,\n    1 - (d.embedding <=> query_embedding) AS similarity\n  FROM documents d\n  WHERE\n    -- если фильтр пустой объект или NULL — пропускаем условие,\n    -- иначе применяем jsonb containment\n    (filter IS NULL OR filter = '{}'::jsonb OR d.metadata @> filter)\n  ORDER BY d.embedding <=> query_embedding\n  LIMIT COALESCE(match_count, NULL);\n$$;",
        "height": 1140,
        "width": 1440,
        "color": 7
      },
      "type": "n8n-nodes-base.stickyNote",
      "position": [
        368,
